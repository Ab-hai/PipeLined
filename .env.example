# Neon Postgres — get this from your Neon project dashboard > Connect > Prisma > .env
DATABASE_URL="postgresql://neondb_owner:[password]@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# NextAuth — generate secret with: openssl rand -base64 32
AUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth — create at github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID="your-github-oauth-app-client-id"
GITHUB_SECRET="your-github-oauth-app-client-secret"

# Google OAuth — create at console.cloud.google.com > APIs & Services > Credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_ID="your-google-client-id"
GOOGLE_SECRET="your-google-client-secret"

GROQ_API_KEY=your_groq_key_here